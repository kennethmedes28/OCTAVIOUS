# Octavious — API keys for the Song Key Lookup feature.
#
# 1. Copy this file to ".env"  (same folder, just remove ".example")
# 2. Fill in ONLY the provider(s) you actually want to use — leave the rest blank
# 3. Set ACTIVE_PROVIDER to whichever one should be used by default
#
# Never commit your real .env file or share it with anyone — it contains secrets.

# Which provider Song Key Lookup uses by default: anthropic | openai | groq | gemini
ACTIVE_PROVIDER=anthropic

# Anthropic (Claude) — supports live web search, most reliable for song lookups
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — supports live web search via the Responses API
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq — fast, but answers from model knowledge only (no live web search)
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — supports live web search via Google Search grounding
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
